# =========================================================================
# Coherence — environment configuration
# Copy to `.env` and fill in.  The whole stack is free; the only choice is
# which free LLM to use.
#
# !!! THE ONE RULE THAT KEEPS IT $0 !!!
# Set BOTH the LLM and the EMBEDDING provider. If you set only one, Cognee
# silently falls back to OpenAI and starts billing you.
# =========================================================================

# ---- Graph + Vector DB (embedded, file-based, free) ----------------------
GRAPH_DATABASE_PROVIDER=kuzu
VECTOR_DB_PROVIDER=lancedb

# =========================================================================
# OPTION A (recommended): Groq free tier for the LLM + Fastembed (CPU) embeds.
# Best extraction quality on a 6GB GPU, since you never load a big LLM locally.
# Get a free key at https://console.groq.com
# =========================================================================
LLM_PROVIDER=groq
LLM_MODEL=groq/llama-3.3-70b-versatile
LLM_API_KEY=gsk_your_free_groq_key_here

EMBEDDING_PROVIDER=fastembed
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
EMBEDDING_DIMENSIONS=384

# =========================================================================
# OPTION B (fully offline): everything local via Ollama, no accounts at all.
# Comment out Option A above and uncomment this block.
# Note: small local models give noisier graphs; great for dev, Groq for the demo.
# (Heads-up: with Ollama embeddings you may hit the HUGGINGFACE_TOKENIZER bug —
#  that's literally one of our open-source PR targets.)
# =========================================================================
# LLM_PROVIDER=ollama
# LLM_MODEL=llama3.1:8b
# LLM_ENDPOINT=http://localhost:11434/v1
# LLM_API_KEY=ollama
# EMBEDDING_PROVIDER=ollama
# EMBEDDING_MODEL=nomic-embed-text
# EMBEDDING_ENDPOINT=http://localhost:11434/api/embed
# EMBEDDING_DIMENSIONS=768

# =========================================================================
# OPTION C (recommended for Gemini-class quality): OpenRouter via OpenAI-compatible API.
# This uses a model comparable to Gemini 2.5 Flash Lite while keeping the stack
# compatible with Cognee's generic OpenAI-compatible client.
# =========================================================================
# LLM_PROVIDER=openrouter
# LLM_MODEL=google/gemini-2.5-flash-lite
# LLM_API_KEY=your_openrouter_key_here
# LLM_ENDPOINT=https://openrouter.ai/api/v1
# EMBEDDING_PROVIDER=fastembed
# EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
# EMBEDDING_DIMENSIONS=384

# ---- App ------------------------------------------------------------------
COHERENCE_DATASET=main_dataset
