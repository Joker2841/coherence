# Copy this file to `.env` to run against Sai's live backend.
# Leave it UNSET (or delete .env) to run in MOCK mode with bundled data —
# that mode needs no backend and is the safe fallback for the demo.
#
# Live mode: start the backend first (single worker, no --reload):
#   uvicorn coherence.server:app --port 8000
VITE_API_BASE=http://localhost:8000
